{
  "name": "phoenix-manager",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "season": "pnpm --filter @phoenix/cli season",
    "indexes": "pnpm --filter @phoenix/database indexes",
    "dev:desktop": "pnpm --filter @phoenix/desktop dev",
    "build:desktop": "pnpm --filter @phoenix/desktop build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
