# Rename to steam-upload.yml and configure secrets to enable.
# Requires self-hosted or platform-specific runners for each depot.

name: Steam Upload (example)

on:
  workflow_dispatch:
    inputs:
      platform:
        description: Platform to build and stage
        required: true
        type: choice
        options:
          - windows
          - macos
          - linux
      branch:
        description: Steam branch (beta or default)
        default: beta

jobs:
  build-and-upload:
    runs-on: ${{ inputs.platform == 'windows' && 'windows-latest' || inputs.platform == 'macos' && 'macos-latest' || 'ubuntu-latest' }}
    steps:
      - uses: actions/checkout@v4

      - uses: subosito/flutter-action@v2
        with:
          channel: stable

      - name: Build Steam depot
        run: ./scripts/build_steam.sh ${{ inputs.platform }}

      - name: Write steam.env from secrets
        shell: bash
        run: |
          mkdir -p steam
          cat > steam/steam.env <<EOF
          STEAM_APP_ID=${{ secrets.STEAM_APP_ID }}
          STEAM_DEPOT_WINDOWS=${{ secrets.STEAM_DEPOT_WINDOWS }}
          STEAM_DEPOT_MACOS=${{ secrets.STEAM_DEPOT_MACOS }}
          STEAM_DEPOT_LINUX=${{ secrets.STEAM_DEPOT_LINUX }}
          STEAM_BUILD_DESC=CI ${{ github.sha }}
          STEAM_BRANCH=${{ inputs.branch }}
          STEAM_SDK_ROOT=${{ secrets.STEAM_SDK_ROOT }}
          STEAM_USERNAME=${{ secrets.STEAM_BUILD_USERNAME }}
          EOF

      - name: Upload via steamcmd
        env:
          STEAM_PASSWORD: ${{ secrets.STEAM_BUILD_PASSWORD }}
        run: ./scripts/upload_steam.sh
