# Copy to steam/steam.env and fill after Steamworks Partner setup.
# steam/steam.env is gitignored — never commit credentials.

# App → Steamworks → Apps → Your App → App Admin → App ID
STEAM_APP_ID=0000000

# SteamPipe → Depots (create in Steamworks → SteamPipe → Depots)
STEAM_DEPOT_WINDOWS=0000001
STEAM_DEPOT_MACOS=0000002
STEAM_DEPOT_LINUX=0000003

# Plataformas a incluir no upload (comma-separated). MVP macOS-only:
# STEAM_PLATFORMS=macos
# Omitir = windows,macos,linux
STEAM_PLATFORMS=macos

# Build label shown in Steamworks Builds tab
STEAM_BUILD_DESC="Phoenix Manager v0.8.0-alpha"

# beta = testers only; default = public (use with care)
STEAM_BRANCH=beta

# Path to Steamworks SDK root (contains tools/ContentBuilder/)
# Download: https://partner.steamgames.com/downloads/steamworks_sdk.zip
STEAM_SDK_ROOT=/path/to/steamworks_sdk

# steamcmd login (create a dedicated build account in Steamworks → Users)
STEAM_USERNAME=your_build_account
